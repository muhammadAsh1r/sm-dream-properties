# App
NEXT_PUBLIC_APP_URL=https://your-domain.vercel.app

# Database (Supabase)
# DATABASE_URL → Transaction pooler, port 6543, ?pgbouncer=true (runtime / Vercel)
# DIRECT_URL   → Session pooler, port 5432 (Prisma migrations only — never use as DATABASE_URL)
# Encode special characters in the password (e.g. ! → %21). Do not wrap values in quotes on Vercel.
DATABASE_URL=
DIRECT_URL=

# Clerk — required for /admin, /sign-in, and image uploads
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
CLERK_WEBHOOK_SECRET=
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up

# Analytics (optional)
NEXT_PUBLIC_GA_MEASUREMENT_ID=
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com
